# =============================================================
# PulseAPI — Master Credentials & Config File
# =============================================================
#
# HOW TO USE:
#   1. Copy this file:  cp .env.template .env
#   2. Fill in every YOUR_* value below
#   3. This file (.env) is in .gitignore — NEVER commit it
#   4. Set the same values in Jenkins (see sections below)
#
# =============================================================

# ── 🔴 SUPER SENSITIVE — Tokens & Passwords ──────────────────
# These go into Jenkins → Manage Jenkins → Credentials → Global
# as the exact Credential ID shown in the comment

# Docker Hub Password or Access Token
# Jenkins Credential ID: dockerhub-credentials  (Username with password)
DOCKERHUB_PASSWORD=YOUR_DOCKERHUB_PASSWORD_OR_TOKEN

# SonarCloud Token (from sonarcloud.io → My Account → Security)
# Jenkins Credential ID: sonar-token  (Secret text)
SONAR_TOKEN=YOUR_SONARCLOUD_TOKEN

# Vercel Token (from vercel.com → Settings → Tokens)
# Jenkins Credential ID: vercel-token  (Secret text)
VERCEL_TOKEN=YOUR_VERCEL_TOKEN

# ── 🟠 PRIVATE CONFIG — Goes into Jenkins Global Env Vars ────
# Jenkins → Manage Jenkins → System → Global Properties → Env Variables
# Add each key=value pair listed below

# Your Docker Hub username (NOT password)
DOCKERHUB_USERNAME=YOUR_DOCKERHUB_USERNAME

# GCP App Server (VM2) External IP
VM2_IP=34.93.153.33

# GCP Jenkins Server (VM1) External IP
VM1_IP=34.14.194.65

# ── 🟡 FIXED CONFIG — Already set, do not change ─────────────
# (These are pre-configured and safe to keep as-is)

SONAR_ORG=samyak-w
SONAR_PROJECT_KEY=samyak-w_pulseapi
SONAR_HOST_URL=https://sonarcloud.io
SONAR_SCANNER_HOME=/home/samyakwaghmare2210/.sonar/sonar-scanner-8.0.1.6346-linux-x64

VM_SSH_USER=samyakwaghmare2210
VM_SSH_KEY_PATH=/home/samyakwaghmare2210/.ssh/pulseapi_app.pem

GITHUB_REPO=https://github.com/samyak-w/pulseapi

# ── 🟢 BACKEND APP CONFIG ─────────────────────────────────────
PORT=3001
NODE_ENV=production
DB_PATH=/app/data/pulseapi.db

# ── 📋 JENKINS SETUP CHECKLIST ───────────────────────────────
#
# Step 1 — Add Jenkins Credentials (Manage Jenkins → Credentials → Global → Add):
#   [x] ID: dockerhub-credentials   Type: Username with password
#         Username: YOUR_DOCKERHUB_USERNAME
#         Password: YOUR_DOCKERHUB_PASSWORD_OR_TOKEN
#
#   [x] ID: sonar-token             Type: Secret text
#         Secret: YOUR_SONARCLOUD_TOKEN
#
#   [x] ID: vercel-token            Type: Secret text
#         Secret: YOUR_VERCEL_TOKEN
#
